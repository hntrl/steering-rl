{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/task-contract.schema.json",
  "title": "Task Contract",
  "type": "object",
  "required": [
    "task_id",
    "title",
    "goal",
    "inputs",
    "expected_outputs",
    "constraints",
    "verify_command",
    "definition_of_done",
    "rollback_note",
    "priority",
    "track",
    "risk_level"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^P[0-2]-\\d{2}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "verify_command": {
      "type": "string",
      "minLength": 1
    },
    "definition_of_done": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "rollback_note": {
      "type": "string",
      "minLength": 1
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2"]
    },
    "track": {
      "type": "string",
      "enum": [
        "runtime",
        "control-plane",
        "evaluation",
        "feedback-loop",
        "rollout"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    }
  },
  "additionalProperties": false
}
