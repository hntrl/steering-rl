{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://steering-rl.local/schemas/doctor-report.schema.json",
  "title": "Doctor Report",
  "description": "Machine-readable output from agent-doctor.mjs --format json",
  "type": "object",
  "required": ["schema_version", "timestamp", "summary", "checks"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "object",
      "required": ["ok", "warn", "fail", "total"],
      "additionalProperties": false,
      "properties": {
        "ok": { "type": "integer", "minimum": 0 },
        "warn": { "type": "integer", "minimum": 0 },
        "fail": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["level", "title", "message"],
        "additionalProperties": false,
        "properties": {
          "level": {
            "type": "string",
            "enum": ["ok", "warn", "fail"]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string"
          },
          "remediation": {
            "type": "string"
          }
        }
      }
    }
  }
}
