{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "experiment-decision.json",
  "title": "Experiment Decision",
  "description": "Schema for experiment promotion decisions produced by the gate checker.",
  "type": "object",
  "required": [
    "experiment_id",
    "champion_profile_id",
    "challenger_profile_id",
    "timestamp",
    "decision",
    "hard_gates",
    "rank_score"
  ],
  "properties": {
    "experiment_id": {
      "type": "string",
      "description": "Unique experiment identifier."
    },
    "champion_profile_id": {
      "type": "string",
      "description": "Profile ID of the current champion."
    },
    "challenger_profile_id": {
      "type": "string",
      "description": "Profile ID of the challenger candidate."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of the decision."
    },
    "decision": {
      "type": "string",
      "enum": ["promote", "hold", "fail"],
      "description": "Final promotion decision."
    },
    "hard_gates": {
      "type": "object",
      "required": ["passed", "results"],
      "properties": {
        "passed": {
          "type": "boolean",
          "description": "True if all hard gates passed."
        },
        "results": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/gate_result"
          },
          "description": "Individual gate results."
        }
      },
      "additionalProperties": false
    },
    "rank_score": {
      "type": ["number", "null"],
      "description": "Weighted rank score for the challenger. Null when hard gates fail."
    },
    "rank_components": {
      "type": ["object", "null"],
      "description": "Breakdown of individual weighted score components.",
      "properties": {
        "correctness": { "type": "number" },
        "coherence": { "type": "number" },
        "concept_adherence": { "type": "number" },
        "solve_rate_norm": { "type": "number" },
        "degenerate_rate_inv": { "type": "number" },
        "latency_norm": { "type": "number" }
      },
      "additionalProperties": false
    },
    "champion_rank_score": {
      "type": ["number", "null"],
      "description": "Weighted rank score for the champion for comparison."
    }
  },
  "additionalProperties": false,
  "definitions": {
    "gate_result": {
      "type": "object",
      "required": ["gate", "passed", "reason"],
      "properties": {
        "gate": {
          "type": "string",
          "description": "Machine-readable gate identifier."
        },
        "passed": {
          "type": "boolean",
          "description": "Whether this gate passed."
        },
        "reason": {
          "type": "string",
          "description": "Machine-readable explanation of the result."
        },
        "actual": {
          "type": ["number", "boolean", "null"],
          "description": "Actual measured value."
        },
        "threshold": {
          "type": ["number", "boolean", "null"],
          "description": "Threshold the value was compared against."
        }
      },
      "additionalProperties": false
    }
  }
}
