{
  "name": "steering-rl",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "tasks:validate": "node scripts/validate-task-contracts.mjs",
    "tasks:issues": "node scripts/create-gh-issues.mjs",
    "agent:supervisor": "node scripts/agent-supervisor.mjs",
    "agent:worker": "node scripts/agent-worker.mjs",
    "agent:reconciler": "node scripts/agent-reconciler.mjs",
    "agent:once": "bash scripts/agent-daemon.sh once",
    "agent:start": "bash scripts/agent-daemon.sh start",
    "agent:stop": "bash scripts/agent-daemon.sh stop",
    "agent:status": "bash scripts/agent-daemon.sh status",
    "agent:follow": "bash scripts/agent-daemon.sh follow",
    "agent:doctor": "node scripts/agent-doctor.mjs",
    "events:validate": "node scripts/validate-events-jsonl.mjs",
    "verify:structure": "node scripts/verify-structure.mjs",
    "verify:json": "node scripts/verify-json.mjs",
    "verify:tasks": "pnpm tasks:validate",
    "contracts:lint": "redocly lint contracts/openapi/inference.yaml && node scripts/contracts-lint.mjs",
    "contracts:test": "node scripts/contracts-test.mjs",
    "verify": "pnpm verify:structure && pnpm verify:json && pnpm verify:tasks && pnpm contracts:lint && pnpm contracts:test",
    "canary:simulation": "pnpm --filter @steering-rl/rollout run canary:simulation",
    "sweep:gemma4:stageA": "node jobs/sweeps/gemma4-stage-a.ts",
    "sweep:gemma4:stageB": "node jobs/sweeps/gemma4-stage-b.ts",
    "sweep:gemma4:stageC": "node jobs/sweeps/gemma4-stage-a.ts && node jobs/sweeps/gemma4-stage-b.ts && node jobs/sweeps/gemma4-stage-c.ts && node jobs/sweeps/tests/gemma4-stage-c.test.ts",
    "sweep:gemma4:stageD": "node jobs/sweeps/gemma4-stage-a.ts && node jobs/sweeps/gemma4-stage-b.ts && node jobs/sweeps/gemma4-stage-c.ts && node jobs/sweeps/gemma4-stage-d.ts && node jobs/sweeps/tests/gemma4-stage-d.test.ts",
    "sweep:gemma4:test": "node jobs/sweeps/tests/gemma4-sweeps.test.ts",
    "trace-miner:dry-run": "pnpm --filter trace-miner run dry-run",
    "promote:nightly": "node jobs/nightly/promote.ts"
  },
  "devDependencies": {
    "@redocly/cli": "^1.34.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
