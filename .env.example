REPO=hntrl/steering-rl
BASE_BRANCH=main

EXECUTOR_BOT_TOKEN=

LANGSMITH_API_KEY=
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING=true
DEEPAGENTS_LANGSMITH_PROJECT=steer-build-agents-staging

DEEPAGENTS_AGENT=build
DEEPAGENTS_SHELL_ALLOW_LIST=cd,git,pnpm,npm,node,npx,python3,bash,sh,ls,cat,head,tail,grep,pwd,which,cp,mv,rm,mkdir,touch
# DEEPAGENTS_MODEL=

MAX_PARALLEL=2
POLL_INTERVAL_SECONDS=60
MAX_AGENT_RUNTIME_MINUTES=20

WORKTREE_BASE=$HOME/worktrees/steering-rl
AGENT_STATE_DIR=$HOME/.agentd/state
AGENT_LOG_DIR=$HOME/.agentd/logs

AGENT_GIT_NAME=steering-agent-executor
AGENT_GIT_EMAIL=steering-agent-executor@users.noreply.github.com
